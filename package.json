{
  "name": "electric-toolbox",
  "private": true,
  "type": "module",
  "description": "CSS toolchain (Tailwind v4) for the Electric Toolbox site generator.",
  "scripts": {
    "build:css": "tailwindcss -i resources/main.css -o build/style.css --minify",
    "watch:css": "tailwindcss -i resources/main.css -o build/style.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "@tailwindcss/typography": "^0.5.16",
    "tailwindcss": "^4.1.0"
  }
}
